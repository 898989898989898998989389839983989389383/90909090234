# Browser deploys can leave this empty for same-origin API calls.
# Android/native builds use https://rbs-academy-current.vercel.app by default.
VITE_API_BASE_URL=

# Server-side admin login. Do not expose these as VITE_* values.
ADMIN_USERNAME=
ADMIN_PASSWORD=
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=
ADMIN_AUTH_SECRET=

# Supabase Postgres connection. Use the transaction pooler URL/port
# (usually 6543) for deployed/serverless apps to avoid session pool limits.
SUPABASE_DB_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_HOST=
SUPABASE_PORT=5432
SUPABASE_USER=
SUPABASE_PASSWORD=
SUPABASE_DATABASE=
SUPABASE_SSL=true
SUPABASE_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_POOL_MAX=1

# Server-side media upload and CDN delivery.
# Find these values in Cloudinary Console -> API Keys.
CLOUDINARY_URL=cloudinary://[API-KEY]:[API-SECRET]@[CLOUD-NAME]
# Optional alternative to CLOUDINARY_URL:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Separate account used only for uploaded PDF notes.
CLOUDINARY_PDF_URL=cloudinary://[PDF-API-KEY]:[PDF-API-SECRET]@[PDF-CLOUD-NAME]
CLOUDINARY_FOLDER=rbs-academy

# Push notification sending from /appcontrol.
# Recommended: paste Firebase service account JSON, or base64-encoded JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional fallback for old FCM projects if you still use a server key.
FCM_SERVER_KEY=
